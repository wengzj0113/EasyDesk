# EasyDesk 前端环境变量配置
# 复制此文件为 .env 并修改相应值

# ===================
# API配置
# ===================
# 开发环境使用 localhost
REACT_APP_API_URL=http://localhost:3001/api
# 生产环境使用 Nginx 代理
# REACT_APP_API_URL=/api

# ===================
# WebSocket配置
# ===================
REACT_APP_WS_URL=ws://localhost:3001

# ===================
# WebRTC配置
# ===================
REACT_APP_WEBRTC_STUN_SERVER=stun:stun.l.google.com:19302
